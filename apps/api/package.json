{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --debounce 500 -r tsconfig-paths/register src/index.ts",
    "ws": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/ws/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:ws": "node dist/ws/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-ses": "^3.600.0",
    "@biopropose/database": "workspace:*",
    "@biopropose/shared-types": "workspace:*",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.11",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.14",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "puppeteer": "^22.11.2",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "ws": "^8.17.1",
    "y-websocket": "^1.5.4",
    "yjs": "^13.6.18",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.11",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
