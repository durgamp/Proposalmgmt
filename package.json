{
  "name": "biopropose",
  "version": "1.0.0",
  "private": true,
  "description": "Biologics RFI/RFP Proposal Management Platform",
  "scripts": {
    "dev": "concurrently \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:ws": "pnpm --filter api ws",
    "build": "pnpm --filter shared-types build && pnpm --filter database build && pnpm --filter api build && pnpm --filter web build",
    "db:migrate": "pnpm --filter database migrate",
    "db:migrate:prod": "pnpm --filter database migrate:prod",
    "db:seed": "pnpm --filter database seed",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "leveldown", "puppeteer"]
  }
}
