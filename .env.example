# ============================================================
# BioPropose Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# ---- App ----
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ---- Database ----
# Options: sqlite | mysql | postgres | mssql
DB_TYPE=sqlite

# SQLite (development only — zero config)
SQLITE_DB_PATH=./biopropose.sqlite

# MySQL (recommended for Docker / production)
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=biopropose
# DB_PASSWORD=biopropose
# DB_NAME=biopropose
# DB_SSL=false
# DB_POOL_MAX=20
# DB_POOL_MIN=5

# PostgreSQL
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_NAME=biopropose
# DB_SSL=false

# MSSQL
# DB_TYPE=mssql
# DB_HOST=your-sql-server.database.windows.net
# DB_PORT=1433
# DB_USER=sa
# DB_PASSWORD=your-mssql-password
# DB_NAME=biopropose
# DB_SSL=true

# ---- AI Provider ------------------------------------------------
# Options: ollama | claude
# Switch with a single env var — no code changes needed.
# ----------------------------------------------------------------
AI_PROVIDER=ollama

# Ollama — local LLM (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT=120000

# Claude / Anthropic API (used when AI_PROVIDER=claude)
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# ---- Email (Nodemailer) ----
# Transport options: smtp | sendgrid | ses | console (dev)
EMAIL_TRANSPORT=console
EMAIL_FROM=noreply@biopropose.com

# SMTP
# EMAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# SendGrid
# EMAIL_TRANSPORT=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# AWS SES
# EMAIL_TRANSPORT=ses
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# ---- File Storage ----
# Options: local | s3
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# S3
# STORAGE_TYPE=s3
# AWS_S3_BUCKET=biopropose-exports
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# ---- Export ----
EXPORT_DIR=./exports
PUPPETEER_HEADLESS=true
EXPORT_TIMEOUT=30000

# ---- Logging ----
LOG_LEVEL=info
LOG_FORMAT=pretty
